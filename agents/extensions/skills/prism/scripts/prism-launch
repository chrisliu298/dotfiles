#!/usr/bin/env bash
set -euo pipefail

# Anti-recursion: a dispatched relay peer inherits RELAY_PEER=<peer>. A peer must
# never trigger prism (mirrors the relay script's own RELAY_PEER guard). This is the
# authoritative block; the relay PATH scrub of this script's dir is defense in depth.
if [ -n "${RELAY_PEER:-}" ]; then
  echo "prism-launch: refused — nested Prism launch from inside a '$RELAY_PEER' peer subprocess (anti-recursion)." >&2
  exit 2
fi

# prism-launch — Prism dispatch launcher
#
# Owns the cross-model (Parallax) half of a Prism run: renders launcher prompts
# from the committed templates, validates dispatch shape mechanically, and fans
# all relay calls out as ONE backgrounded process that waits for every peer and
# emits a single structured result. The same-model subagent half stays in the
# conversation as Agent-tool calls — a shell script cannot (and must not) launch
# Claude agents, and `claude -p` is never used for Claude here (it is only
# relay's transport for DeepSeek/MiMo).
#
# Usage:
#   prism-launch prepare --config <config.json>      # foreground: render + validate + manifest
#   prism-launch parallax <manifest.json> [--dry-run] # ONE backgrounded call: fan out all peers
#   prism-launch --help | --version
#
# Subcommands and the manifest are documented in the prism SKILL.md.

VERSION=1

die() { echo "prism-launch: $*" >&2; exit 1; }

# Templates live in a sibling directory of this script's parent (scripts/../templates).
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
TEMPLATES_DIR=$(cd "$SCRIPT_DIR/../templates" && pwd 2>/dev/null) \
  || die "templates dir not found next to script ($SCRIPT_DIR/../templates)"

# ── --dispatch parser ─────────────────────────────────────────────────────────
# Compiles the line-oriented dispatch format into the same JSON shape that
# --config accepts; cmd_prepare's existing validation/render path then runs
# unchanged. This parser does NO business validation (peers, efforts, duplicates,
# injection) — that stays single-sourced in the jq pass below. Its only job is to
# assemble JSON safely (via `jq -n --arg`, never string concatenation), so the
# orchestrator authors a literal, escaping-free file with the Write tool instead
# of raw JSON.

DISPATCH_CONFIG=""
DP_packet=""; DP_px=""; DP_sa=""
DP_type=""; DP_to=""; DP_name=""; DP_effort=""; DP_lens=""; DP_desc=""; DP_in=0; DP_seen=""

dp_trim() { local s="$1"; s="${s#"${s%%[![:space:]]*}"}"; s="${s%"${s##*[![:space:]]}"}"; printf '%s' "$s"; }

dp_norm_effort() {
  local e; e=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
  case "$e" in
    m|medium) printf 'medium' ;;
    x|xhigh)  printf 'xhigh'  ;;
    l|low)    printf 'low'    ;;
    h|high)   printf 'high'   ;;
    -|'')     printf ''       ;;
    *)        printf '%s' "$1" ;;   # pass original through; the jq pass validates it against the peer registry
  esac
}

# Emit the in-progress record as one JSON object onto the parallax/subagent
# accumulators. Parallax Name defaults to the slugified Lens when omitted.
dp_flush() {
  [ "$DP_in" -eq 1 ] || { DP_in=0; return 0; }
  local obj
  case "$DP_type" in
    parallax)
      obj=$(jq -n --arg to "$DP_to" --arg name "$DP_name" --arg effort "$DP_effort" \
                  --arg lens "$DP_lens" --arg desc "$DP_desc" '
        ($lens | ascii_downcase | gsub("[^a-z0-9]+"; "-") | gsub("(^-|-$)"; "")) as $auto
        | {to:$to, lens:$lens, lens_desc:$desc, name:(if $name != "" then $name else $auto end)}
        + (if $effort != "" then {effort:$effort} else {} end)')
      DP_px="$DP_px$obj"$'\n' ;;
    subagent)
      [ -z "$DP_to$DP_name$DP_effort" ] || die "prepare: --dispatch subagent record must not set To/Name/Effort (those are parallax-only; did you mean 'Type: parallax'?)"
      obj=$(jq -n --arg lens "$DP_lens" --arg desc "$DP_desc" '{lens:$lens, lens_desc:$desc}')
      DP_sa="$DP_sa$obj"$'\n' ;;
    *) die "prepare: --dispatch record has invalid or missing Type '$DP_type' (must be 'parallax' or 'subagent')" ;;
  esac
  DP_type=""; DP_to=""; DP_name=""; DP_effort=""; DP_lens=""; DP_desc=""; DP_in=0
}

# Parse a --dispatch file into a normalized config JSON file. Sets DISPATCH_CONFIG
# to that path; die()s on any structural error.
dispatch_to_config() {
  local file="$1" line t key val lineno=0
  DP_packet=""; DP_px=""; DP_sa=""
  DP_type=""; DP_to=""; DP_name=""; DP_effort=""; DP_lens=""; DP_desc=""; DP_in=0; DP_seen=""

  while IFS= read -r line || [ -n "$line" ]; do
    lineno=$((lineno + 1))
    t=$(dp_trim "$line")
    [ -z "$t" ] && { dp_flush; continue; }
    case "$t" in
      \#*) continue ;;                       # comment line
      *:*) key=$(dp_trim "${t%%:*}"); val=$(dp_trim "${t#*:}") ;;
      *)   die "prepare: --dispatch line $lineno missing ':' separator: $line" ;;
    esac
    case "$key" in
      Shared-Packet)
        [ -z "$DP_packet" ] || die "prepare: --dispatch has more than one Shared-Packet line"
        DP_packet="$val" ;;
      Type)
        dp_flush; DP_in=1; DP_type="$val"; DP_seen="" ;;
      To|Name|Effort|Lens|Lens-Desc)
        [ "$DP_in" -eq 1 ] || die "prepare: --dispatch line $lineno: '$key' appears before any 'Type:' record"
        case " $DP_seen " in *" $key "*) die "prepare: --dispatch line $lineno: duplicate '$key' in one record" ;; esac
        DP_seen="$DP_seen $key"
        case "$key" in
          To)        DP_to="$val" ;;
          Name)      DP_name="$val" ;;
          Effort)    DP_effort=$(dp_norm_effort "$val") ;;
          Lens)      DP_lens="$val" ;;
          Lens-Desc) DP_desc="$val" ;;
        esac ;;
      *) die "prepare: --dispatch line $lineno: unknown key '$key' (valid: Shared-Packet, Type, To, Name, Effort, Lens, Lens-Desc)" ;;
    esac
  done < "$file"
  dp_flush

  [ -n "$DP_packet" ] || die "prepare: --dispatch missing required 'Shared-Packet:' line"
  case "$DP_packet" in
    /*) ;;
    *)  die "prepare: --dispatch Shared-Packet must be an absolute path: $DP_packet" ;;
  esac
  case "$DP_packet" in
    *[[:space:]]*|*'*'*|*'?'*|*'['*) die "prepare: --dispatch Shared-Packet must not contain whitespace or glob characters: $DP_packet" ;;
  esac

  local pxj saj cfg gen
  pxj=$(printf '%s' "$DP_px" | jq -s '.')
  saj=$(printf '%s' "$DP_sa" | jq -s '.')
  cfg=$(jq -n --arg p "$DP_packet" --argjson px "$pxj" --argjson sa "$saj" \
        '{shared_packet:$p, parallax:$px, subagents:$sa}')
  gen="${DP_packet%.md}-config.normalized.json"
  printf '%s\n' "$cfg" > "$gen" || die "prepare: could not write normalized config: $gen"
  DISPATCH_CONFIG="$gen"
}

# ── prepare ──────────────────────────────────────────────────────────────────

cmd_prepare() {
  local config="" dispatch=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --config)   [ $# -ge 2 ] || die "prepare: --config requires a value";   config="$2";   shift 2 ;;
      --dispatch) [ $# -ge 2 ] || die "prepare: --dispatch requires a value"; dispatch="$2"; shift 2 ;;
      -*)         die "prepare: unknown flag: $1" ;;
      *)          die "prepare: unexpected argument: $1" ;;
    esac
  done
  [ -n "$config" ] && [ -n "$dispatch" ] && die "prepare: pass --config OR --dispatch, not both"
  [ -z "$config" ] && [ -z "$dispatch" ] && die "prepare: --config <config.json> or --dispatch <dispatch-file> required"
  command -v jq >/dev/null 2>&1 || die "prepare: jq not found in PATH"
  # --dispatch: compile the line-oriented file into the canonical config JSON,
  # then fall through to the exact same validation/render path as --config.
  if [ -n "$dispatch" ]; then
    [ -f "$dispatch" ] || die "prepare: dispatch file not found: $dispatch"
    dispatch_to_config "$dispatch"   # sets DISPATCH_CONFIG; die()s on a parse error
    config="$DISPATCH_CONFIG"
  fi
  [ -f "$config" ] || die "prepare: config file not found: $config"

  # Peer registry — relay's sibling file, the single source of truth for which
  # peers exist, their effort knobs, and their launcher template style.
  local PEERS="$SCRIPT_DIR/../../relay/peers.json"
  [ -f "$PEERS" ] || die "prepare: peer registry not found at \$SCRIPT_DIR/../../relay/peers.json ($PEERS)"

  local cfgerr
  cfgerr=$(jq -e . "$config" 2>&1 >/dev/null) || die "prepare: config is not valid JSON: $config
  jq: ${cfgerr:-no parse detail}. Common causes: trailing comma, unescaped quote, unbalanced braces. Author the config with the Write tool (literal content), or use --dispatch — never a shell heredoc."
  jq -e . "$PEERS"  >/dev/null 2>&1 || die "prepare: peer registry is not valid JSON: $PEERS"

  local packet
  packet=$(jq -r '.shared_packet // ""' "$config")
  [ -n "$packet" ]            || die "prepare: config.shared_packet is required"
  case "$packet" in /*) ;; *) die "prepare: shared_packet must be an absolute path: $packet" ;; esac
  # Reject whitespace/glob: run_base derives from this path, and the per-peer log
  # paths are carried through space-joined arrays in cmd_parallax (fail-closed).
  case "$packet" in *[[:space:]]*|*'*'*|*'?'*|*'['*) die "prepare: shared_packet path must not contain whitespace or glob characters: $packet" ;; esac
  [ -f "$packet" ]            || die "prepare: shared_packet not found: $packet"
  [ -s "$packet" ]            || die "prepare: shared_packet is empty: $packet"
  grep -q '^## Full Question' "$packet" || die "prepare: shared_packet missing '## Full Question' section"
  grep -q '^## Context'       "$packet" || die "prepare: shared_packet missing '## Context' section"
  # Constraints: the anti-recursion guard requires this block verbatim, so the
  # script OWNS it. Author the packet with just Full Question + Context (+ Reference
  # Materials); prepare injects the canonical block here when it is absent.
  # Idempotent — present (e.g. a prepare re-run on the same packet) → left as-is.
  if ! grep -q '^## Constraints' "$packet"; then
    local cfile="$TEMPLATES_DIR/shared-constraints.md"
    [ -f "$cfile" ] || die "prepare: canonical constraints template missing: $cfile"
    { printf '\n'; cat "$cfile"; } >> "$packet" || die "prepare: could not inject constraints into $packet"
    echo "prism-launch: injected canonical ## Constraints into $(basename "$packet")" >&2
  elif ! grep -q 'read-only leaf node' "$packet"; then
    # A bespoke block is allowed, but it MUST keep the load-bearing anti-recursion
    # guard — a present-but-abbreviated Constraints section is the exact safety
    # hole the injection is meant to close, so fail closed on it.
    die "prepare: the packet's ## Constraints section is missing the anti-recursion guard ('read-only leaf node'). Remove the section to let prepare inject the canonical block, or restore the verbatim text from templates/shared-constraints.md."
  fi
  # How-to-answer: a presentation-only block (verdict-first, cite sources, no
  # preamble). Unlike Constraints it carries no safety load, so it is injected
  # AFTER Constraints (so it's the freshest instruction before the agent answers)
  # and never fails closed on a bespoke section. Idempotent — present → left as-is.
  if ! grep -q '^## How to answer' "$packet"; then
    local hfile="$TEMPLATES_DIR/shared-how-to-answer.md"
    [ -f "$hfile" ] || die "prepare: canonical how-to-answer template missing: $hfile"
    { printf '\n'; cat "$hfile"; } >> "$packet" || die "prepare: could not inject how-to-answer into $packet"
    echo "prism-launch: injected canonical ## How to answer into $(basename "$packet")" >&2
  fi

  # run_base: shared_packet path minus a trailing .md. All run artifacts hang off it.
  local run_base="${packet%.md}"
  local manifest="${run_base}-manifest.json"
  local run_id; run_id=$(basename "$run_base")
  # Clear any stale artifacts from a prior run on the same packet so a failed
  # prepare cannot leave an authoritative-looking manifest/result behind. Never
  # delete the normalized config the current --dispatch run just generated (it is
  # $config here, read by the jq pass below) — only a stale one from a prior run.
  rm -f "$manifest" "${run_base}-result.json" "${run_base}-digest.md"
  [ "$config" = "${run_base}-config.normalized.json" ] || rm -f "${run_base}-config.normalized.json"

  # Single jq pass: validate structure/enums/effort/injection/dup-lenses, then
  # emit the authoritative manifest (computed names, launcher paths, counts).
  local manifest_json
  manifest_json=$(jq \
      --arg base "$run_base" \
      --arg tdir "$TEMPLATES_DIR" \
      --argjson peers "$(cat "$PEERS")" '
    def bad($m): error($m);
    def chktext($field):
      if (type != "string") then bad($field + " must be a non-empty string")
      elif test("^[[:space:]]*$") then bad($field + " must not be empty or all-whitespace")
      elif test("</") then bad($field + " contains \"</\" (injection guard — it can break the CO-STAR XML scaffolding). Rephrase without the literal \"</\", e.g. write \"closing tag\". Offending value: " + .)
      elif test("\\{\\{") then bad($field + " contains \"{{\" (injection guard — it collides with the template {{SLOT}} markers). Rephrase without the literal \"{{\", e.g. write \"double-brace placeholder\". Offending value: " + .)
      elif (. == "FILL") or test("^FILL-[0-9]+$") then bad($field + " is still the scaffold placeholder \"" + . + "\" — replace every FILL / FILL-<n> with a real lens before dispatch.")
      else . end;

    (.shared_packet) as $pkt
    | (.parallax // []) as $px
    | (.subagents // []) as $sa
    | ($px | type) as $pxt | (if $pxt != "array" then bad("parallax must be an array") else . end)
    | ($sa | type) as $sat | (if $sat != "array" then bad("subagents must be an array") else . end)

    # Validate + normalize parallax entries against the peer registry.
    | ($peers | keys) as $valid_peers
    | ($px | map(
        (.to // bad("parallax entry missing .to")) as $to
        | ($peers[$to] // bad("parallax .to must be one of " + ($valid_peers|join("|")) + ", got: " + $to)) as $peer
        | (.name // bad("parallax entry missing .name")) as $name
        | (if ($name|test("^[a-z0-9-]+$")|not) then bad("parallax .name must match [a-z0-9-]+, got: " + $name) else . end)
        | (.lens | chktext("parallax .lens")) as $lens
        | (.lens_desc | chktext("parallax .lens_desc")) as $desc
        | ($peer.effort_values) as $evals
        | (if ($evals == null) and ((.effort // null) != null)
             then bad("effort is only valid for peers with an effort knob; remove it from " + $to + " entry \"" + $name + "\"") else . end)
        | (if $evals != null
             then ((.effort // ($peer.default_effort // $evals[0])) as $e
                   | if (($evals | index($e)) == null) then bad($to + " effort must be one of " + ($evals|join("|")) + ", got: " + $e) else $e end)
             else null end) as $effort
        | {
            to: $to,
            name: ("prism-" + $name),
            slug: $name,
            effort: $effort,
            lens: $lens,
            lens_desc: $desc,
            template: ($peer.template // bad("registry peer " + $to + " has no .template")),
            launcher: ($base + "-launcher-" + $to + "-" + $name + ".md"),
            log:      ($base + "-out-prism-" + $name + ".log")
          }
      )) as $pxn

    # Validate + normalize subagent entries (slugify lens for the filename).
    | ($sa | map(
        (.lens | chktext("subagent .lens")) as $lens
        | (.lens_desc | chktext("subagent .lens_desc")) as $desc
        | ($lens | ascii_downcase | gsub("[^a-z0-9]+"; "-") | gsub("(^-|-$)"; "")) as $slug
        | (if $slug == "" then bad("subagent .lens must contain at least one [a-z0-9] character to form a launcher filename: " + $lens) else . end)
        | { lens: $lens, lens_desc: $desc, slug: $slug, launcher: ($base + "-launcher-subagent-" + $slug + ".md") }
      )) as $san

    # All lens names across the whole run must be distinct (redundancy guard).
    | (($pxn + $san) | map(.lens)) as $lenses
    | (if ($lenses|length) != ($lenses|unique|length) then bad("duplicate lens name in run; every agent needs a distinct lens") else . end)
    | ($pxn | map(.name)) as $names
    | (if ($names|length) != ($names|unique|length) then bad("duplicate parallax name; each relay --name must be distinct (it keys the per-peer log)") else . end)
    | ($san | map(.slug)) as $saslugs
    | (if ($saslugs|length) != ($saslugs|unique|length) then bad("two subagent lenses slugify to the same launcher filename; make the lens names more distinct") else . end)

    # Per-peer counts derived from the dispatch, not a hardcoded peer list.
    | ($pxn | group_by(.to) | map({key: .[0].to, value: length}) | from_entries) as $by_peer
    | {
        version: 1,
        id: ($base | split("/") | last),
        shared_packet: $pkt,
        templates_dir: $tdir,
        counts: {
          subagents: ($san|length),
          by_peer: $by_peer,
          parallax_total: ($pxn|length),
          dispatched_total: (($san|length) + ($pxn|length))
        },
        parallax: $pxn,
        subagents: $san
      }
  ' "$config") || die "prepare: validation failed (see message above)"

  # Render every launcher FROM the manifest (manifest is authoritative — no drift).
  # Substitution is literal bash parameter expansion, so lens text cannot break
  # sed delimiters or replacement specials.
  local n i to tmplname slug lens desc launcher tmpl tpl rendered first
  n=$(echo "$manifest_json" | jq '.parallax | length')
  i=0
  while [ "$i" -lt "$n" ]; do
    to=$(echo "$manifest_json"       | jq -r ".parallax[$i].to")
    tmplname=$(echo "$manifest_json" | jq -r ".parallax[$i].template")
    lens=$(echo "$manifest_json"     | jq -r ".parallax[$i].lens")
    desc=$(echo "$manifest_json"     | jq -r ".parallax[$i].lens_desc")
    launcher=$(echo "$manifest_json" | jq -r ".parallax[$i].launcher")
    tmpl="$TEMPLATES_DIR/launcher-relay-$tmplname.tmpl"
    [ -f "$tmpl" ] || die "prepare: template not found: $tmpl (peer $to, template '$tmplname')"
    tpl=$(cat "$tmpl")
    rendered="${tpl//\{\{SHARED_PACKET_PATH\}\}/$packet}"
    rendered="${rendered//\{\{LENS_NAME\}\}/$lens}"
    rendered="${rendered//\{\{LENS_DESC\}\}/$desc}"
    case "$rendered" in *'{{'*) die "prepare: unreplaced {{slot}} in rendered launcher for $to/$lens" ;; esac
    first=$(printf '%s\n' "$rendered" | head -1)
    case "$first" in CRITICAL:*) ;; *) die "prepare: rendered $to launcher does not start with the anti-recursion CRITICAL line" ;; esac
    printf '%s\n' "$rendered" > "$launcher"
    i=$((i + 1))
  done

  n=$(echo "$manifest_json" | jq '.subagents | length')
  tmpl="$TEMPLATES_DIR/launcher-subagent.tmpl"
  [ -f "$tmpl" ] || die "prepare: template not found: $tmpl"
  tpl=$(cat "$tmpl")
  i=0
  while [ "$i" -lt "$n" ]; do
    lens=$(echo "$manifest_json"    | jq -r ".subagents[$i].lens")
    desc=$(echo "$manifest_json"    | jq -r ".subagents[$i].lens_desc")
    launcher=$(echo "$manifest_json"| jq -r ".subagents[$i].launcher")
    rendered="${tpl//\{\{SHARED_PACKET_PATH\}\}/$packet}"
    rendered="${rendered//\{\{LENS_NAME\}\}/$lens}"
    rendered="${rendered//\{\{LENS_DESC\}\}/$desc}"
    case "$rendered" in *'{{'*) die "prepare: unreplaced {{slot}} in rendered subagent launcher for $lens" ;; esac
    first=$(printf '%s\n' "$rendered" | head -1)
    case "$first" in CRITICAL:*) ;; *) die "prepare: rendered subagent launcher does not start with the anti-recursion CRITICAL line" ;; esac
    printf '%s\n' "$rendered" > "$launcher"
    i=$((i + 1))
  done

  # Write the manifest atomically, only after every launcher rendered cleanly.
  printf '%s\n' "$manifest_json" > "$manifest.tmp" && mv "$manifest.tmp" "$manifest"

  # Human-facing summary for the orchestrator.
  local nsub peershape
  nsub=$(echo "$manifest_json" | jq '.counts.subagents')
  # Display in canonical (docs) order — codex, the two Grok tiers, then DeepSeek, MiMo —
  # not jq's alphabetical key order; any future peer not in the list is appended.
  peershape=$(echo "$manifest_json" | jq -r '
    .counts.by_peer as $bp
    | ["codex","grok-build","grok-composer","deepseek","mimo"] as $ord
    | ($ord + ($bp | keys | map(select(. as $k | ($ord | index($k)) == null))))
    | map(select($bp[.] != null) | "\(.)=\($bp[.])")
    | join(" ")')

  echo "prism-launch: run '$run_id' prepared — all checks passed."
  echo "dispatch shape: subagents=$nsub ${peershape:-(no parallax)}"
  local ptot nnotif; ptot=$(echo "$manifest_json" | jq '.counts.parallax_total'); nnotif=$nsub
  [ "$ptot" -gt 0 ] && nnotif=$((nsub + 1))
  echo "wait for $nnotif completion notification(s): one per subagent ($nsub)$([ "$ptot" -gt 0 ] && echo ' + one for the parallax batch')."
  echo
  # Actionable next-steps FIRST (the bulky subagent launcher dump goes last, so the
  # parallax command and manifest path stay easy to find at any N).
  if [ "$(echo "$manifest_json" | jq '.counts.parallax_total')" -gt 0 ]; then
    echo "Parallax — ONE backgrounded Bash call dispatches all cross-model peers:"
    echo "  $0 parallax $manifest"
    echo
  fi
  echo "manifest: $manifest"
  if [ "$nsub" -gt 0 ]; then
    echo "REMINDER: this does NOT dispatch the $nsub Claude subagent(s) — issue those"
    echo "Agent-tool calls yourself using the launcher contents below. Never use 'claude -p'."
    echo
    echo "Subagent launcher contents (copy each delimited block as one Agent-tool prompt;"
    echo "the file path is shown if you'd rather Read it):"
    echo
    local slens slaunch
    while IFS=$'\t' read -r slens slaunch; do
      echo "════ SUBAGENT: $slens  ($slaunch)"
      echo "────────8<──────── copy from here ────────8<────────"
      cat "$slaunch"
      echo "────────8<──────── to here ────────8<────────"
      echo
    done < <(echo "$manifest_json" | jq -r '.subagents[] | .lens + "\t" + .launcher')
  fi
}

# ── parallax ─────────────────────────────────────────────────────────────────

cmd_parallax() {
  local manifest="" dry_run=false only=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=true; shift ;;
      --only)    [ $# -ge 2 ] || die "parallax: --only requires a peer name"; only="$2"; shift 2 ;;
      -*)        die "parallax: unknown flag: $1" ;;
      *)         [ -z "$manifest" ] || die "parallax: unexpected argument: $1"; manifest="$1"; shift ;;
    esac
  done
  [ -n "$manifest" ] || die "parallax: <manifest.json> required"
  [ -f "$manifest" ] || die "parallax: manifest not found: $manifest"
  command -v jq >/dev/null 2>&1 || die "parallax: jq not found in PATH"
  jq -e . "$manifest" >/dev/null 2>&1 || die "parallax: manifest is not valid JSON: $manifest"

  local packet run_base result n
  packet=$(jq -r '.shared_packet' "$manifest")
  run_base="${packet%.md}"
  result="${run_base}-result.json"
  n=$(jq '.parallax | length' "$manifest")
  [ "$n" -gt 0 ] || die "parallax: manifest has no parallax calls"

  # Resolve relay by its installed sibling path first (PATH-independent), then
  # fall back to PATH. This mirrors invoking prism-launch by absolute path, so a
  # sanitized/non-zsh shell that lacks the skills dir on PATH still dispatches.
  local relay_bin="$SCRIPT_DIR/../../relay/scripts/relay"
  [ -x "$relay_bin" ] || relay_bin="$(command -v relay || true)"
  [ -n "$relay_bin" ] && [ -x "$relay_bin" ] \
    || die "parallax: relay not found at \$SCRIPT_DIR/../../relay/scripts/relay or in PATH"
  [ -f "$packet" ] || die "parallax: shared_packet not found: $packet"

  # Per-peer timeout wrapper (optional — coreutils on macOS). Set
  # PRISM_PEER_TIMEOUT=0 to disable the cap entirely (peers run unbounded; the
  # only backstop is the outer Bash-tool timeout, which kills all peers at once).
  local TIMEOUT_BIN="" PEER_TIMEOUT="${PRISM_PEER_TIMEOUT:-3600}"
  if [ "$PEER_TIMEOUT" = "0" ]; then
    echo "prism-parallax: per-peer timeout disabled (PRISM_PEER_TIMEOUT=0)" >&2
  elif command -v timeout >/dev/null 2>&1; then TIMEOUT_BIN=timeout
  elif command -v gtimeout >/dev/null 2>&1; then TIMEOUT_BIN=gtimeout; fi
  [ -z "$TIMEOUT_BIN" ] && [ "$PEER_TIMEOUT" != "0" ] && echo "prism-parallax: warning: no timeout/gtimeout in PATH — per-peer timeout disabled" >&2

  # --only <name>: re-dispatch a SINGLE peer (retry) and merge its result into the
  # existing <id>-result.json, leaving the other peers' results intact. The name
  # matches the relay --name (with or without the prism- prefix) or the lens slug.
  if [ -n "$only" ]; then
    local oi to name effort launcher log
    # Match by relay name (prism-<slug> or <slug>), lens slug, or model (.to). A
    # model that ran multiple peers (N>1) is ambiguous — require the lens name then.
    oi=$(jq -r --arg q "$only" '
      [.parallax[] | (.name == ("prism-"+$q)) or (.name==$q) or (.slug==$q) or (.to==$q)] as $m
      | ($m | map(select(.)) | length) as $cnt
      | if $cnt == 0 then "none" elif $cnt > 1 then "ambig" else ($m | index(true) | tostring) end' "$manifest")
    case "$oi" in
      none)  die "parallax --only: no peer matching '$only' (names: $(jq -r '[.parallax[].slug]|join(", ")' "$manifest"))" ;;
      ambig) die "parallax --only: '$only' matches multiple peers — use a specific lens name (one of: $(jq -r '[.parallax[].slug]|join(", ")' "$manifest"))" ;;
    esac
    to=$(jq -r ".parallax[$oi].to" "$manifest")
    name=$(jq -r ".parallax[$oi].name" "$manifest")
    effort=$(jq -r ".parallax[$oi].effort // \"\"" "$manifest")
    launcher=$(jq -r ".parallax[$oi].launcher" "$manifest")
    log=$(jq -r ".parallax[$oi].log" "$manifest")
    [ -f "$launcher" ] || die "parallax --only: launcher missing (re-run prepare): $launcher"
    set -- "$relay_bin" call --to "$to" --name "$name"
    [ -n "$effort" ] && set -- "$@" --effort "$effort"
    if $dry_run; then
      echo "prism-parallax: DRY RUN --only — 1 peer call, nothing dispatched."
      echo "  $* < $launcher"
      exit 0
    fi
    [ -n "$TIMEOUT_BIN" ] && set -- "$TIMEOUT_BIN" "$PEER_TIMEOUT" "$@"
    echo "prism-parallax: re-dispatching $to/$name (retry)" >&2
    local ec=0; "$@" < "$launcher" >/dev/null 2>"$log" || ec=$?
    local res status; res=$(sed -n 's/^relay: response → //p' "$log" 2>/dev/null | tail -1)
    if [ -n "$res" ] && [ -s "$res" ] && [ "$ec" = "0" ]; then status=done; else status=error; res=""; fi
    local newentry id; id=$(jq -r '.id' "$manifest")
    newentry=$(jq -n --arg to "$to" --arg name "$name" --arg status "$status" --arg res "$res" --arg log "$log" \
        '{to:$to, name:$name, status:$status, res:(if $res=="" then null else $res end), log:$log}')
    # Merge into the existing result ONLY if it is non-empty, valid JSON with a
    # .results array. Empty/malformed (e.g. an interrupted prior fan) → write a
    # fresh result with just this peer rather than corrupting it (fail closed).
    if [ -s "$result" ] && jq -e '(.results | type) == "array"' "$result" >/dev/null 2>&1; then
      if ! jq --argjson new "$newentry" '
        (.results | map(.name) | index($new.name)) as $i
        | .results = (if $i == null then .results + [$new] else (.results[0:$i] + [$new] + .results[($i+1):]) end)
        | .succeeded = ([.results[]|select(.status=="done")]|length)
        | .failed    = ([.results[]|select(.status!="done")]|length)
        | .expected  = (.results|length)' "$result" > "$result.tmp"; then
        rm -f "$result.tmp"; die "parallax --only: could not merge retry result into $result"
      fi
      mv "$result.tmp" "$result"
    else
      printf '%s\n' "$newentry" | jq -s --arg id "$id" \
        '{id:$id, expected:(.|length), succeeded:([.[]|select(.status=="done")]|length), failed:([.[]|select(.status!="done")]|length), results:.}' > "$result"
    fi
    echo "prism-parallax: $to/$name → $status${res:+  $res}"
    echo "result: $result"
    if [ "$status" = "done" ]; then return 0; else return 1; fi
  fi

  # Verify every launcher exists before launching anything.
  local i to name effort launcher
  i=0
  while [ "$i" -lt "$n" ]; do
    launcher=$(jq -r ".parallax[$i].launcher" "$manifest")
    [ -f "$launcher" ] || die "parallax: launcher file missing (re-run prepare): $launcher"
    i=$((i + 1))
  done

  if $dry_run; then
    echo "prism-parallax: DRY RUN — $n peer call(s), nothing dispatched."
    i=0
    while [ "$i" -lt "$n" ]; do
      to=$(jq -r ".parallax[$i].to" "$manifest")
      name=$(jq -r ".parallax[$i].name" "$manifest")
      effort=$(jq -r ".parallax[$i].effort // \"\"" "$manifest")
      launcher=$(jq -r ".parallax[$i].launcher" "$manifest")
      if [ -n "$effort" ]; then
        echo "  $relay_bin call --to $to --name $name --effort $effort < $launcher"
      else
        echo "  $relay_bin call --to $to --name $name < $launcher"
      fi
      i=$((i + 1))
    done
    exit 0
  fi

  # Launch all peers concurrently. Parallel index arrays (bash 3.2-safe).
  local pids="" names="" tos="" logs="" rc_of=""
  i=0
  while [ "$i" -lt "$n" ]; do
    to=$(jq -r ".parallax[$i].to" "$manifest")
    name=$(jq -r ".parallax[$i].name" "$manifest")
    effort=$(jq -r ".parallax[$i].effort // \"\"" "$manifest")
    launcher=$(jq -r ".parallax[$i].launcher" "$manifest")
    local log; log=$(jq -r ".parallax[$i].log" "$manifest")

    # Build the relay command; pass --effort when the manifest carries one (codex, grok-build).
    set -- "$relay_bin" call --to "$to" --name "$name"
    [ -n "$effort" ] && set -- "$@" --effort "$effort"
    [ -n "$TIMEOUT_BIN" ] && set -- "$TIMEOUT_BIN" "$PEER_TIMEOUT" "$@"

    # Discard relay's stdout (it just echoes the .res.md we read directly) and
    # capture only relay's own diagnostics on stderr. Parsing the response path
    # from a stream that never carries model output makes it unspoofable.
    "$@" < "$launcher" > /dev/null 2> "$log" &
    pids="$pids $!"
    names="$names $name"
    tos="$tos $to"
    logs="$logs $log"
    echo "prism-parallax: launched $to/$name (pid $!)" >&2
    i=$((i + 1))
  done

  # If we are terminated mid-fan (e.g. the outer Bash-tool timeout fires), kill
  # the in-flight peers rather than leaving them orphaned.
  trap 'for _p in $pids; do kill "$_p" 2>/dev/null || true; done' INT TERM HUP

  # Wait for EVERY child even if some fail. errexit must not abort the loop or
  # kill survivors, so each wait is guarded inside an `if`.
  set -- $pids
  local idx=1 pid
  for pid in "$@"; do
    if wait "$pid"; then rc_of="$rc_of $idx:0"; else rc_of="$rc_of $idx:$?"; fi
    idx=$((idx + 1))
  done
  trap - INT TERM HUP

  # Build per-peer results from logs (response path + status). Sentinel is
  # written only after every wait above has returned.
  local results="" tarr narr larr ec res status succeeded=0 failed=0
  set -- $tos;   tarr="$*"
  set -- $names; narr="$*"
  set -- $logs;  larr="$*"
  i=1
  while [ "$i" -le "$n" ]; do
    to=$(echo "$tarr"   | cut -d' ' -f"$i")
    name=$(echo "$narr" | cut -d' ' -f"$i")
    local log; log=$(echo "$larr" | cut -d' ' -f"$i")
    ec=$(echo "$rc_of" | tr ' ' '\n' | grep "^$i:" | cut -d: -f2)
    # Strip the exact "relay: response → " prefix so paths containing spaces
    # survive intact (unlike awk $NF). The log holds only relay's stderr.
    res=$(sed -n 's/^relay: response → //p' "$log" 2>/dev/null | tail -1)
    if [ -n "$res" ] && [ -s "$res" ] && [ "${ec:-1}" = "0" ]; then
      status=done; succeeded=$((succeeded + 1))
    else
      status=error; failed=$((failed + 1)); res=""
    fi
    results="$results
$(jq -n --arg to "$to" --arg name "$name" --arg status "$status" --arg res "$res" --arg log "$log" \
        '{to:$to, name:$name, status:$status, res:(if $res=="" then null else $res end), log:$log}')"
    i=$((i + 1))
  done

  printf '%s\n' "$results" | jq -s \
      --arg id "$(jq -r '.id' "$manifest")" \
      --argjson expected "$n" \
      --argjson succeeded "$succeeded" \
      --argjson failed "$failed" \
      '{id:$id, expected:$expected, succeeded:$succeeded, failed:$failed, results:.}' \
      > "$result"

  echo "prism-parallax: $succeeded/$n succeeded, $failed failed"
  jq -r '.results[] | "  " + (if .status=="done" then "done " else "error" end) + " " + .to + "  " + .name + "  " + (.res // ("(no response; see " + .log + ")"))' "$result"
  echo "result: $result"
  echo "REMINDER: Claude subagents are dispatched separately via the Agent tool; this result covers parallax only." >&2

  [ "$failed" -eq 0 ]
}

# ── scaffold ─────────────────────────────────────────────────────────────────

# Standard one-line weighing-posture descriptions for the common lenses, grouped by
# axis family (see SKILL.md "Lens Axes"), used to pre-fill --preset scaffolds (refine
# as needed). The menu is open — unknown names get a generic stub, not an error.
lens_desc_for() {
  case "$1" in
    # Search axis
    Breadth-Weighted)    echo "weigh wide coverage of options and angles over depth" ;;
    Depth-Weighted)      echo "weigh deep, thorough analysis of the core over breadth" ;;
    # Reframe axis
    First-Principles)    echo "weigh how this looks rebuilt from the goal up, ignoring the current shape" ;;
    Outsider)            echo "weigh how a newcomer from another field would approach it" ;;
    Reframe)             echo "weigh an alternate prior or problem framing that recasts the question (exploratory, not an attack)" ;;
    Lateral-Generative)  echo "weigh deliberately non-obvious, out-of-the-box options via analogy, inversion, or constraint removal — novelty over coverage" ;;
    # Evidence axis
    Empirical)           echo "weigh the claim by what is measurable: baseline, metric, magnitude, base rate — distrust unmeasured assertions" ;;
    Correctness)         echo "weigh correctness guarantees and edge cases" ;;
    # Mechanism axis
    Causal)              echo "weigh the actual cause-and-effect chain down to the root" ;;
    # Challenge axis (opt-in)
    Adversarial)         echo "weigh the strongest attacks, flaws, and failure modes — find what breaks" ;;
    Falsification)       echo "weigh what evidence would prove the leading hypothesis wrong" ;;
    Disconfirming)       echo "weigh the evidence that most directly contradicts the leading choice" ;;
    Risk)                echo "weigh what could go wrong and the blast radius if it does" ;;
    # Human / Value axis
    Stakeholder)         echo "weigh who is affected and how: incentives, who bears the cost, second-order effects on the people and systems it touches" ;;
    Audience)            echo "weigh how the intended audience will actually receive it" ;;
    Clarity)             echo "weigh how clearly the message lands for its reader" ;;
    # Delivery axis
    Pragmatist)          echo "weigh the workable path that ships under real constraints — resources, sequencing, what it takes to execute" ;;
    Simplicity)          echo "weigh the approach with the fewest moving parts" ;;
    Structural)          echo "weigh the structurally correct fix at the needed scope — reject the expedient hack and scope-padding alike (durable means correct, not bigger)" ;;
    # Time axis
    Temporal)            echo "weigh how the answer changes over time: lifecycle, sequencing, reversibility (one-way vs two-way doors), path dependence" ;;
    *)                   echo "weigh the $1 axis — refine this description" ;;
  esac
}

# Six distinct lenses per task-type preset, in canonical tier order (heaviest-
# reasoning first, so it lands on the subagent/codex slots). Each set spreads across
# distinct axis families (see SKILL.md "Lens Axes"). Returns 1 if unknown.
preset_lenses() {
  case "$1" in
    review)    echo "Adversarial Correctness Simplicity Depth-Weighted Temporal Outsider" ;;
    design)    echo "First-Principles Adversarial Simplicity Stakeholder Temporal Empirical" ;;
    diagnosis) echo "Causal Falsification Empirical Depth-Weighted Temporal Outsider" ;;
    compare)   echo "First-Principles Empirical Simplicity Stakeholder Temporal Disconfirming" ;;
    research)  echo "First-Principles Breadth-Weighted Depth-Weighted Outsider Empirical Lateral-Generative" ;;
    decision)  echo "First-Principles Empirical Stakeholder Temporal Pragmatist Disconfirming" ;;
    writing)   echo "Adversarial Clarity Audience Simplicity Outsider Empirical" ;;
    *) return 1 ;;
  esac
}

# Emit a ready-to-fill dispatch skeleton for the symmetric default (N of every
# model, one shared effort). With --preset <task-type>, pre-fill six lenses (N=1).
# Otherwise replace each "FILL" Lens / Lens-Desc, then Write it as the dispatch
# file. Removes the mechanical Type/To/Effort/order boilerplate.
cmd_scaffold() {
  local n=1 effort="m" packet="" preset=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --n)      [ $# -ge 2 ] || die "scaffold: --n requires a value";      n="$2";      shift 2 ;;
      --effort) [ $# -ge 2 ] || die "scaffold: --effort requires a value"; effort="$2"; shift 2 ;;
      --packet) [ $# -ge 2 ] || die "scaffold: --packet requires a value"; packet="$2"; shift 2 ;;
      --preset) [ $# -ge 2 ] || die "scaffold: --preset requires a value"; preset="$2"; shift 2 ;;
      -*) die "scaffold: unknown flag: $1" ;;
      *)  die "scaffold: unexpected argument: $1" ;;
    esac
  done
  case "$n" in ''|*[!0-9]*) die "scaffold: --n must be a positive integer" ;; esac
  [ "$n" -ge 1 ] || die "scaffold: --n must be >= 1"
  local cdx gbe ef
  case "$effort" in
    m|medium)        cdx="m"; gbe="m"; ef="m"  ;;
    xh|x|xhigh|high) cdx="x"; gbe="h"; ef="xh" ;;
    *) die "scaffold: --effort must be m or xh" ;;
  esac
  [ -n "$packet" ] || packet="/tmp/prism-<id>.md"

  if [ -n "$preset" ]; then
    [ "$n" -eq 1 ] || die "scaffold: --preset is for the N=1 default; for N>1, fill lenses by hand"
    local names; names=$(preset_lenses "$preset") \
      || die "scaffold: unknown --preset '$preset' (try: review design diagnosis compare research decision writing)"
    set -- $names
    printf 'Shared-Packet: %s\n\n' "$packet"
    printf '# Preset "%s" (effort=%s): six lenses pre-filled in canonical tier order.\n' "$preset" "$ef"
    printf '# Edit any Lens / Lens-Desc to taste; write the Shared-Packet file before prepare.\n\n'
    printf 'Type: subagent\nLens: %s\nLens-Desc: %s\n\n' "$1" "$(lens_desc_for "$1")"
    printf 'Type: parallax\nTo: codex\nEffort: %s\nLens: %s\nLens-Desc: %s\n\n' "$cdx" "$2" "$(lens_desc_for "$2")"
    printf 'Type: parallax\nTo: grok-build\nEffort: %s\nLens: %s\nLens-Desc: %s\n\n' "$gbe" "$3" "$(lens_desc_for "$3")"
    printf 'Type: parallax\nTo: grok-composer\nLens: %s\nLens-Desc: %s\n\n' "$4" "$(lens_desc_for "$4")"
    printf 'Type: parallax\nTo: deepseek\nLens: %s\nLens-Desc: %s\n\n' "$5" "$(lens_desc_for "$5")"
    printf 'Type: parallax\nTo: mimo\nLens: %s\nLens-Desc: %s\n\n' "$6" "$(lens_desc_for "$6")"
    return 0
  fi

  printf 'Shared-Packet: %s\n\n' "$packet"
  printf '# Symmetric scaffold: N=%s of each of the six models, effort=%s.\n' "$n" "$ef"
  printf '# Replace every "FILL" Lens / Lens-Desc (prepare rejects any leftover FILL).\n'
  printf '# Order is the canonical tier order — put your heaviest-reasoning (e.g. Adversarial)\n'
  printf '# lens on a subagent or codex. Write the Shared-Packet file before running prepare.\n'
  printf '# Tip: --preset review|design|diagnosis|compare|research|decision|writing pre-fills lenses (N=1).\n\n'
  local k i=0
  k=1; while [ "$k" -le "$n" ]; do
    i=$((i+1)); printf 'Type: subagent\nLens: FILL-%s\nLens-Desc: FILL\n\n' "$i"; k=$((k+1))
  done
  k=1; while [ "$k" -le "$n" ]; do
    i=$((i+1)); printf 'Type: parallax\nTo: codex\nEffort: %s\nLens: FILL-%s\nLens-Desc: FILL\n\n' "$cdx" "$i"; k=$((k+1))
  done
  k=1; while [ "$k" -le "$n" ]; do
    i=$((i+1)); printf 'Type: parallax\nTo: grok-build\nEffort: %s\nLens: FILL-%s\nLens-Desc: FILL\n\n' "$gbe" "$i"; k=$((k+1))
  done
  local peer
  for peer in grok-composer deepseek mimo; do
    k=1; while [ "$k" -le "$n" ]; do
      i=$((i+1)); printf 'Type: parallax\nTo: %s\nLens: FILL-%s\nLens-Desc: FILL\n\n' "$peer" "$i"; k=$((k+1))
    done
  done
}

# ── clean ────────────────────────────────────────────────────────────────────

# Remove every temp artifact for a run: /tmp/prism-<id>* (packet, dispatch,
# normalized config, manifest, rendered launchers, out logs, result).
cmd_clean() {
  local target="${1:-}"
  [ -n "$target" ] || die "clean: <run-id or packet path> required (removes /tmp/prism-<id>*)"
  # Reject anything that could widen the trailing glob or escape the prism temp
  # prefix BEFORE deriving base — a target like '*' or '../..' must never reach rm.
  case "$target" in
    *'*'*|*'?'*|*'['*) die "clean: target must not contain glob characters (* ? [): $target" ;;
    *..*)             die "clean: target must not contain '..': $target" ;;
  esac
  local base
  case "$target" in
    # packet/artifact path → strip the known run-artifact suffixes so any of them
    # resolves to the run base (not a partial clean).
    /*) base="${target%.md}"; base="${base%.dispatch}"
        base="${base%-manifest.json}"; base="${base%-result.json}"; base="${base%-config.normalized.json}" ;;
    *)  base="/tmp/prism-${target#prism-}" ;;   # bare id (with or without the prism- prefix)
  esac
  case "$base" in /tmp/prism-?*) ;; *) die "clean: refusing to remove '$base*' — only a specific /tmp/prism-<id>* is allowed" ;; esac
  case "${base#/tmp/prism-}" in */*) die "clean: run id must not contain '/': $target" ;; esac
  local matches; matches=$(ls -d "$base"* 2>/dev/null | wc -l | tr -d ' ')
  rm -f "$base"*
  echo "prism-launch: removed $matches artifact(s) matching ${base}*"
}

# ── results ──────────────────────────────────────────────────────────────────

# Print each parallax peer's status + .res.md path from <id>-result.json (written
# by `parallax`), so the orchestrator reads one structured view instead of parsing
# the backgrounded task's stdout. Exits non-zero if any peer failed.
cmd_results() {
  local manifest="${1:-}"
  [ -n "$manifest" ] || die "results: <manifest.json> required"
  [ -f "$manifest" ] || die "results: manifest not found: $manifest"
  command -v jq >/dev/null 2>&1 || die "results: jq not found in PATH"
  local packet base result
  packet=$(jq -r '.shared_packet' "$manifest")
  base="${packet%.md}"; result="${base}-result.json"
  [ -f "$result" ] || die "results: no result file yet ($result) — has the parallax fan finished?"
  [ -s "$result" ] && jq -e '(.results | type) == "array"' "$result" >/dev/null 2>&1 \
    || die "results: result file is empty or malformed: $result"
  echo "prism-launch: parallax results for '$(jq -r '.id // "?"' "$result")'"
  jq -r '.results[] | "  [" + (if .status=="done" then "done " else "ERROR" end) + "] " + .to + "  " + .name + "  " + (.res // ("(failed — see " + .log + ")"))' "$result"
  # Recompute counts from .results rather than trusting (possibly stale) counters.
  echo "summary: $(jq -r '([.results[]|select(.status=="done")]|length) as $ok | "\($ok)/\(.results|length) succeeded, \((.results|length)-$ok) failed"' "$result")"
  [ "$(jq '[.results[]|select(.status!="done")]|length' "$result")" -eq 0 ]
}

# ── digest ─────────────────────────────────────────────────────────────────

# Collapse two Grok tiers to one lineage; every other peer is its own lineage.
# Mirrors the SKILL.md tally rule (grok-build + grok-composer = one Grok lineage).
digest_lineage_of() {
  case "$1" in
    grok-build|grok-composer) echo "grok" ;;
    *)                        echo "$1"   ;;
  esac
}

# Extract each parallax peer's "## Digest" block from its .res.md into one small,
# lineage-tagged file, so the orchestrator can synthesize from compact digests on a
# large run and deep-read only the full .res.md it needs. Subagent + self digests
# already live in the orchestrator conversation, so they are not extracted here.
# Reads <id>-result.json (written by parallax); writes <id>-digest.md. Compaction
# only — it never decides; failures/missing-digests are surfaced, not fatal.
cmd_digest() {
  local manifest="" out=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --out) [ $# -ge 2 ] || die "digest: --out requires a value"; out="$2"; shift 2 ;;
      -*)    die "digest: unknown flag: $1" ;;
      *)     [ -z "$manifest" ] || die "digest: unexpected argument: $1"; manifest="$1"; shift ;;
    esac
  done
  [ -n "$manifest" ] || die "digest: <manifest.json> required"
  [ -f "$manifest" ] || die "digest: manifest not found: $manifest"
  command -v jq >/dev/null 2>&1 || die "digest: jq not found in PATH"
  jq -e . "$manifest" >/dev/null 2>&1 || die "digest: manifest is not valid JSON: $manifest"

  local packet base result id n
  packet=$(jq -r '.shared_packet' "$manifest")
  base="${packet%.md}"; result="${base}-result.json"
  id=$(jq -r '.id // "?"' "$manifest")
  [ -f "$result" ] || die "digest: no result file yet ($result) — has the parallax fan finished?"
  [ -s "$result" ] && jq -e '(.results | type) == "array"' "$result" >/dev/null 2>&1 \
    || die "digest: result file is empty or malformed: $result"
  [ -n "$out" ] || out="${base}-digest.md"
  n=$(jq '.results | length' "$result")

  local i to name res status lineage block extracted=0 warns=0
  {
    printf '# Prism digest — %s\n' "$id"
    printf '# %s parallax peer(s). Subagent + self digests are in the orchestrator conversation, not here.\n' "$n"
    printf '# Deep-read a peer'\''s full .res.md when its digest dissents, looks weak, or is the tie-breaker.\n\n'
    i=0
    while [ "$i" -lt "$n" ]; do
      to=$(jq -r ".results[$i].to" "$result")
      name=$(jq -r ".results[$i].name" "$result")
      status=$(jq -r ".results[$i].status" "$result")
      res=$(jq -r ".results[$i].res // \"\"" "$result")
      lineage=$(digest_lineage_of "$to")
      printf '## %s · %s  (lineage: %s)\n' "$to" "$name" "$lineage"
      if [ "$status" != "done" ] || [ -z "$res" ]; then
        printf '_peer failed — no response (see %s)_\n\n' "$result"; warns=$((warns + 1))
      elif [ ! -f "$res" ]; then
        printf '_response file missing: %s_\n\n' "$res"; warns=$((warns + 1))
      else
        # Capture the LAST top-level "## Digest" block, ignoring anything inside
        # ``` code fences — so a fenced template example can't false-match, and a
        # fenced digest degrades to a clean miss (→ deep-read) rather than leaking
        # trailing prose into the digest. Starts only at an H2 `## Digest` (with an
        # optional trailing :/. decoration), stops at the next H1/H2 heading so a
        # deeper `###` line inside the digest doesn't truncate it. BSD-awk-safe
        # (no interval `{1,2}` or gawk `\>` — uses `#[#]?`).
        block=$(awk '
          /^```/                                                 { infence = !infence; next }
          infence                                                { next }
          tolower($0) ~ /^##[[:space:]]+digest[[:space:].:-]*$/   { cap=1; buf=""; next }
          cap && /^#[#]?[[:space:]]/                              { cap=0 }
          cap                                                     { buf = buf $0 "\n" }
          END                                                    { printf "%s", buf }
        ' "$res")
        if [ -n "$(printf '%s' "$block" | tr -d '[:space:]')" ]; then
          printf '%s\n\n_full: %s_\n\n' "$block" "$res"; extracted=$((extracted + 1))
        else
          printf '_no `## Digest` block found — read the full response: %s_\n\n' "$res"; warns=$((warns + 1))
        fi
      fi
      i=$((i + 1))
    done
  } > "$out"

  # Exit 0 even at 0/n — digest is compaction-only (surfaced, not fatal); the
  # orchestrator reads the summary and falls back to the full .res.md. But when
  # nothing extracted, name the likely cause so the empty digest isn't a mystery.
  [ "$extracted" -gt 0 ] || [ "$n" -eq 0 ] || \
    echo "prism-launch: note — 0 digests extracted; peers may predate the ## Digest requirement (re-run prepare on a fresh packet) or fenced their digest. Read the full .res.md files." >&2
  echo "prism-launch: wrote digest for '$id' → $out"
  echo "summary: $extracted/$n peer digest(s) extracted, $warns warning(s)"
}

# ── main ─────────────────────────────────────────────────────────────────────

cmd_help() {
  cat <<'USAGE'
prism-launch — Prism dispatch launcher (parallax fan-out + dispatch prep)

Usage:
  prism-launch scaffold [--n <N>] [--effort m|xh] [--preset <type>] [--packet <path>]  # fill-in dispatch skeleton
  prism-launch prepare  --dispatch <dispatch-file>   # default: line-oriented control file
  prism-launch prepare  --config   <config.json>     # escape hatch: raw JSON (one of the two)
  prism-launch parallax <manifest.json> [--dry-run]
  prism-launch parallax <manifest.json> --only <peer-name>   # re-dispatch ONE peer (retry), merge into result
  prism-launch results  <manifest.json>              # print each peer's status + .res.md path
  prism-launch digest   <manifest.json> [--out <path>]  # extract peers' ## Digest blocks into one small file
  prism-launch clean    <run-id | packet-path>       # rm -f /tmp/prism-<id>*
  prism-launch --help | --version  ·  prism-launch <subcommand> --help

scaffold:  emit a ready-to-fill dispatch skeleton for the symmetric default (N of each of the
           six models, one shared effort). Replace each "FILL" Lens/Lens-Desc, then Write it.
           --preset <review|design|diagnosis|compare|research|decision|writing> pre-fills six
           lenses by task type (N=1).
prepare:   validate the dispatch/config, render all launchers from templates, write a manifest;
           inject the canonical ## Constraints and ## How to answer into the shared packet if
           absent (so you author the packet with just Full Question + Context). Pass one of --dispatch
           (compiled to the canonical config) or --config. See the prism SKILL.md.
parallax:  fan out every relay call as ONE backgrounded process, wait for all, write a structured
           result. Run with run_in_background: true. --only <name> retries a single failed peer.
results:   print each parallax peer's status + .res.md path from the run's result.json.
digest:    extract each parallax peer's "## Digest" block (lineage-tagged) into one small
           <id>-digest.md, so synthesis at large N reads compact digests + deep-reads only
           the .res.md it needs. Subagent + self digests are already in the conversation.
clean:     remove every temp artifact for a run (/tmp/prism-<id>*).

Env:
  PRISM_PEER_TIMEOUT  per-peer timeout in seconds (default 3600; 0 = no cap; needs coreutils timeout).
USAGE
}

[ $# -ge 1 ] || { cmd_help; exit 1; }
case "$1" in
  --help|-h)    cmd_help; exit 0 ;;
  --version|-V) echo "prism-launch v$VERSION"; exit 0 ;;
esac
sub="$1"; shift
case "${1:-}" in --help|-h) cmd_help; exit 0 ;; esac   # `prism-launch <sub> --help`
case "$sub" in
  prepare)  cmd_prepare  "$@" ;;
  parallax) cmd_parallax "$@" ;;
  scaffold) cmd_scaffold "$@" ;;
  results)  cmd_results  "$@" ;;
  digest)   cmd_digest   "$@" ;;
  clean)    cmd_clean    "$@" ;;
  *)        die "unknown subcommand: $sub (use prepare|parallax|scaffold|results|digest|clean)" ;;
esac
