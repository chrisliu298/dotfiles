# =============================================================================
# macOS
# =============================================================================

# =============================================================================
# Terminal
# =============================================================================

# Reset stuck mouse tracking (Ghostty + TUI apps / SSH disconnect)
disable_mouse_tracking() {
    printf '\e[?1000l\e[?1002l\e[?1003l\e[?1006l' >/dev/tty 2>/dev/null
}


# =============================================================================
# macOS
# =============================================================================

if (( IS_MACOS )); then
    # Safe rm using trash (strips rm-specific flags that trash doesn't understand)
    rm() {
        local args=()
        for arg in "$@"; do
            # Skip common rm flags that trash doesn't support
            [[ "$arg" =~ ^-[rRfivdP]+$ ]] && continue
            [[ "$arg" == "--" ]] && continue
            [[ "$arg" == "--recursive" ]] && continue
            [[ "$arg" == "--force" ]] && continue
            [[ "$arg" == "--interactive" ]] && continue
            [[ "$arg" == "--verbose" ]] && continue
            args+=("$arg")
        done
        [[ ${#args[@]} -gt 0 ]] && trash "${args[@]}"
    }

    # Rename macOS device (hostname, local hostname, computer name)
    rename_device() {
        scutil --set HostName "$1"
        scutil --set LocalHostName "$1"
        scutil --set ComputerName "$1"
    }
fi

# =============================================================================
# Dotfiles
# =============================================================================

# Install dotfiles locally, then sync to remote machines
dfs() {
    local _d=$'\033[2m' _b=$'\033[1m' _c=$'\033[36m'
    local _g=$'\033[32m' _r=$'\033[31m' _0=$'\033[0m'

    # Section header helper (matches dotfiles.sh: 60 visible chars)
    _sec() {
        local t="$1" total_width=60
        local prefix="  ── $t "
        local pad="" i len=$(( total_width - ${#prefix} ))
        (( len < 4 )) && len=4
        for (( i = 0; i < len; i++ )); do pad+="─"; done
        printf '\n  %s── %s %s%s\n' "${_b}${_c}" "$t" "${pad}${_0}" ""
    }

    # Pull latest changes
    _sec "Pull"
    if git -C ~/dotfiles pull --ff-only >/dev/null 2>&1; then
        printf "     ✓ ${_d}up to date${_0}\n"
    else
        printf "     ${_r}✗ pull failed${_0}\n"
        return 1
    fi

    # Local install
    _sec "Install"
    ~/dotfiles/dotfiles.sh
    local local_rc=$?
    if (( local_rc )); then
        printf "     ${_r}✗ local install failed${_0}\n"
        return $local_rc
    fi

    # Remote sync (macOS only — requires SSH hosts)
    (( IS_MACOS )) || return 0

    local hosts=(macmini l40s)
    local tmpdir=$(mktemp -d)
    local pids=()
    local n=${#hosts[@]}

    _sec "Sync ($n hosts)"

    # Disable job control to suppress [1] PID / [1]+ Done noise
    set +m

    for h in "${hosts[@]}"; do
        command ssh "$h" "cd ~/dotfiles && git pull --ff-only 2>&1 && ./dotfiles.sh 2>&1; printf '\\n__RC__=%d\\n' \$?" \
            > "$tmpdir/$h.log" 2>&1 &
        pids+=($!)
    done

    local failed=0 idx=1
    for h in "${hosts[@]}"; do
        wait "${pids[$idx]}" 2>/dev/null
        # Check the embedded exit code rather than wait's return code
        if tail -1 "$tmpdir/$h.log" | grep -q '^__RC__=0$'; then
            printf "     ${_g}✓${_0} %s\n" "$h"
        else
            printf "     ${_r}✗${_0} %s\n" "$h"
            sed '/^__RC__=/d' "$tmpdir/$h.log" | sed "s/^/       ${_d}│${_0} /"
            ((++failed))
        fi
        ((++idx))
    done

    set -m 2>/dev/null  # restore (may fail in non-interactive shells)
    rm -rf "$tmpdir"

    if (( failed )); then
        printf "\n  ${_r}${failed} failed${_0}\n\n"
    else
        printf "\n  ${_g}✨ All synced.${_0}\n\n"
    fi
    return $failed
}

# =============================================================================
# Claude Code / Codex
# =============================================================================

# Fix qmd v2 broken bin wrapper (dirname doesn't resolve symlinks, so DIR is wrong)
qmd(){ node "$(npm root -g)/@tobilu/qmd/dist/cli/qmd.js" "$@"; }

# Unset TMUX for Claude Code so Bun's getColorDepth() doesn't short-circuit
# to 256-color (the `if (env.TMUX) return 8` check fires before COLORTERM).
_claude(){ env -u TMUX COLORTERM=truecolor "$(command -v claude)" "$@"; }
c(){ _claude --dangerously-skip-permissions "$@"; }
cc(){ _claude --dangerously-skip-permissions --continue "$@"; }
cr(){ _claude --dangerously-skip-permissions --resume "$@"; }
crc(){ _claude rc --dangerously-skip-permissions "$@"; }
cu(){ command claude update "$@"; }
cap(){ local prompt="/atomic-push"; (( $# )) && prompt+=" ${*}"; _claude -p --dangerously-skip-permissions "$prompt"; }
cpu(){ local prompt="/push"; (( $# )) && prompt+=" ${*}"; _claude -p --dangerously-skip-permissions "$prompt"; }
chl(){ (( $# )) || { echo 'Usage: chl "<prompt>"'; return 1; }; _claude -p --dangerously-skip-permissions "${*}"; }

x(){ command codex --yolo -m gpt-5.4 --config model_reasoning_effort=high "$@"; }
xl(){ command codex --yolo -m gpt-5.4 --config model_reasoning_effort=low "$@"; }
xm(){ command codex --yolo -m gpt-5.4 --config model_reasoning_effort=medium "$@"; }
xh(){ command codex --yolo -m gpt-5.4 --config model_reasoning_effort=high "$@"; }
xc(){ command codex resume --last --yolo "$@"; }
xr(){ command codex resume --yolo "$@"; }
xu(){ npm install -g @openai/codex@latest "$@"; }
xhl(){ (( $# )) || { echo 'Usage: xhl "<prompt>"'; return 1; }; command codex exec --yolo -m gpt-5.4 --config model_reasoning_effort=high "${*}"; }
