# =============================================================================
# macOS
# =============================================================================

# =============================================================================
# Terminal
# =============================================================================

# Reset stuck mouse tracking (Ghostty + TUI apps / SSH disconnect)
disable_mouse_tracking() {
    printf '\e[?1000l\e[?1002l\e[?1003l\e[?1006l' >/dev/tty 2>/dev/null
}


# =============================================================================
# macOS
# =============================================================================

if (( IS_MACOS )); then
    # Safe rm using trash (strips rm-specific flags that trash doesn't understand)
    rm() {
        local args=()
        for arg in "$@"; do
            # Skip common rm flags that trash doesn't support
            [[ "$arg" =~ ^-[rRfivdP]+$ ]] && continue
            [[ "$arg" == "--" ]] && continue
            [[ "$arg" == "--recursive" ]] && continue
            [[ "$arg" == "--force" ]] && continue
            [[ "$arg" == "--interactive" ]] && continue
            [[ "$arg" == "--verbose" ]] && continue
            args+=("$arg")
        done
        [[ ${#args[@]} -gt 0 ]] && trash "${args[@]}"
    }

    # Rename macOS device (hostname, local hostname, computer name)
    rename_device() {
        scutil --set HostName "$1"
        scutil --set LocalHostName "$1"
        scutil --set ComputerName "$1"
    }
fi

# =============================================================================
# Dotfiles
# =============================================================================

# Install dotfiles locally, then sync to remote machines
dfs() {
    # Pull latest changes
    printf "\033[1m=> Pulling latest changes\033[0m\n"
    git -C ~/dotfiles pull --ff-only
    local pull_rc=$?
    if (( pull_rc )); then
        printf "   pull      \033[31m✗\033[0m (exit %d)\n" "$pull_rc"
        return $pull_rc
    fi
    printf "   pull      \033[32m✓\033[0m\n"

    # Local install
    printf "\033[1m=> Installing dotfiles locally\033[0m\n"
    ~/dotfiles/dotfiles.sh
    local local_rc=$?
    if (( local_rc )); then
        printf "   local     \033[31m✗\033[0m (exit %d)\n" "$local_rc"
        return $local_rc
    fi
    printf "   local     \033[32m✓\033[0m\n"

    # Remote sync (macOS only — requires SSH hosts)
    (( IS_MACOS )) || return 0

    local hosts=(macmini l40s)
    local tmpdir=$(mktemp -d)
    local pids=()

    printf "\033[1m=> Syncing dotfiles to %d hosts\033[0m\n" ${#hosts[@]}

    for h in "${hosts[@]}"; do
        printf "   %-10s syncing...\n" "$h"
        ssh "$h" "cd ~/dotfiles && git pull --ff-only 2>&1 && ./dotfiles.sh 2>&1" \
            > "$tmpdir/$h.log" 2>&1 &
        pids+=($!)
    done

    local failed=0
    for i in {1..${#hosts[@]}}; do
        if wait "${pids[$i]}" 2>/dev/null; then
            printf "   %-10s \033[32m✓\033[0m\n" "${hosts[$i]}"
        else
            printf "   %-10s \033[31m✗\033[0m\n" "${hosts[$i]}"
            sed 's/^/   │ /' "$tmpdir/${hosts[$i]}.log"
            ((failed++))
        fi
    done

    rm -rf "$tmpdir"
    printf "\033[1m=> Done.\033[0m"
    (( failed )) && printf " \033[31m(%d failed)\033[0m" "$failed"
    printf "\n"
    return $failed
}

# =============================================================================
# Claude Code / Codex
# =============================================================================

# Fix qmd v2 broken bin wrapper (dirname doesn't resolve symlinks, so DIR is wrong)
qmd(){ node "$(npm root -g)/@tobilu/qmd/dist/cli/qmd.js" "$@"; }

c(){ command claude --dangerously-skip-permissions "$@"; }
cc(){ command claude --dangerously-skip-permissions --continue "$@"; }
cr(){ command claude --dangerously-skip-permissions --resume "$@"; }
crc(){ command claude rc --dangerously-skip-permissions "$@"; }
cu(){ command claude update "$@"; }
cap(){ local prompt="/atomic-push"; (( $# )) && prompt+=" ${*}"; command claude -p --dangerously-skip-permissions "$prompt"; }
cpu(){ local prompt="/push"; (( $# )) && prompt+=" ${*}"; command claude -p --dangerously-skip-permissions "$prompt"; }
chl(){ (( $# )) || { echo 'Usage: ch "<prompt>"'; return 1; }; command claude -p --dangerously-skip-permissions "${*}"; }

x(){ command codex --yolo -m gpt-5.4 "$@"; }
xl(){ command codex --yolo -m gpt-5.4 --config model_reasoning_effort=low "$@"; }
xm(){ command codex --yolo -m gpt-5.4 --config model_reasoning_effort=medium "$@"; }
xh(){ command codex --yolo -m gpt-5.4 --config model_reasoning_effort=high "$@"; }
xc(){ command codex resume --last --yolo "$@"; }
xr(){ command codex resume --yolo "$@"; }
xu(){ npm install -g @openai/codex@latest "$@"; }
xhl(){ (( $# )) || { echo 'Usage: xh "<prompt>"'; return 1; }; command codex exec --yolo -m gpt-5.4 --config model_reasoning_effort=high "${*}"; }
