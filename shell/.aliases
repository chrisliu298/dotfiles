# =============================================================================
# Shell
# =============================================================================
alias ls="ls --color"
alias l="ls -lha"
alias ez="exec zsh"
alias fx='printf "\e[?1000l\e[?1002l\e[?1003l\e[?1006l"'
alias b="btop"
alias kl="killall"
# dfs is a function in shell/.functions (local install + remote sync)
if (( IS_MACOS )); then
    alias o="open"
else
    alias o="xdg-open"
fi

# =============================================================================
# Tmux
# =============================================================================
alias t="tmux"
alias ta="tmux attach -t"
alias tad="tmux attach -d -t"
alias tl="tmux list-sessions"
alias tn="tmux new-session -s"
alias tk="tmux kill-session -t"
alias tka="tmux kill-server"
alias to='tmux new-session -A -s "$(basename $PWD)"'
alias trs="tmux rename-session -t"

# =============================================================================
# Python / uv
# =============================================================================
alias sv="source .venv/bin/activate"
alias upi="uv pip install"
alias uvp="uv venv --python"
alias us="uv sync"
alias ua="uv add"

# =============================================================================
# Git
# =============================================================================
alias glog="git log --oneline --graph --decorate --all"

# =============================================================================
# Proxy
# =============================================================================
alias proxy="export https_proxy=http://127.0.0.1:7897; export http_proxy=http://127.0.0.1:7897; export all_proxy=socks5://127.0.0.1:7897"
alias unproxy="unset https_proxy http_proxy all_proxy"

# =============================================================================
# Quartz
# =============================================================================
alias nqs="npx quartz sync"
alias nqb="npx quartz build --serve"
alias nqu="npx quartz upload"

# =============================================================================
# Claude Code
# =============================================================================
# Defined as functions in shell/.functions to support shared base args.
alias ct="uv run --directory ~/Developer/GitHub/claude-usage-tracker ~/Developer/GitHub/claude-usage-tracker/main.py"
alias adb="uv run --directory ~/Developer/GitHub/adb ~/Developer/GitHub/adb/adb.py"

# =============================================================================
# Codex
# =============================================================================
# Defined as functions in shell/.functions to support shared base args.

# =============================================================================
# macOS-Only
# =============================================================================
if (( IS_MACOS )); then
    # Navigation
    alias github="$HOME/Developer/GitHub"
    alias obs="$HOME/Documents/Obsidian/chrisliu298"
    alias d="$HOME/dotfiles"

    # Homebrew
    alias bi="brew install"
    alias bu="brew uninstall"
    alias bic="brew install --cask"
    alias buz="brew uninstall --zap"
    alias bupd="brew update"
    alias bupg="brew upgrade"
    alias bs="brew search"
    alias bl="brew list"
    alias bo="brew outdated"
    alias buu="brew update && brew upgrade"

    # SSH
    alias sm="ssh macmini"
    alias sl="ssh l40s"

    # Tailscale
    alias tu="tailscale up"
    alias td="tailscale down"
    alias ts="tailscale status"

    # Recall
    alias recall-sync="bash ~/.claude/skills/recall/sync_remotes.sh"

    # Miscellaneous
    alias update_user_js="$HOME/Documents/Sync/Apps/Betterfox/update_user_js.py"
fi
